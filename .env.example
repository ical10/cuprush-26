# Postgres connection string. Local dev expects a database created with
# `createdb worldcup_hilo` on the default Homebrew Postgres socket.
DATABASE_URL=postgresql://localhost:5432/worldcup_hilo

# Port the Hono server (API + production client) listens on.
PORT=3000

# privy (default) = real Privy verification; dev = local auth stub, must be
# set explicitly and refuses to run when NODE_ENV is prod-ish. Leaving this
# unset selects privy, which fails closed without PRIVY_APP_ID/SECRET below.
AUTH_MODE=dev

# TxLINE ingestion (devnet, service level 1). replay (default) streams the captured
# JSON fixtures in src/txline/fixtures/samples; live connects to the real
# TxLINE API with the credentials below. TXLINE_BASE_URL is the origin only
# (e.g. https://txline-dev.txodds.com), WITHOUT the /api suffix — the client
# appends paths itself. TXLINE_API_KEY is the durable X-Api-Token; the guest
# JWT is minted automatically at runtime.
TXLINE_MODE=replay
TXLINE_API_KEY=
TXLINE_BASE_URL=
# ms between replayed events; 0 applies every captured event immediately.
TXLINE_REPLAY_INTERVAL_MS=1500
# Optional alternate directory of captured replay JSON files (README smoke test).
#TXLINE_FIXTURES_DIR=

# Privy app credentials (email OTP + embedded Solana wallet + sponsorship).
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# OpenRouter key for LLM-assisted question selection (small model, background
# only, never in a request path). Off by default — set LLM_SELECTOR=on and
# provide OPENROUTER_API_KEY to enable; otherwise the deterministic template
# fallback is always used.
OPENROUTER_API_KEY=
LLM_SELECTOR=off
OPENROUTER_MODEL=openai/gpt-4o-mini

# On-chain adapter. CHAIN_MODE=solana activates the real devnet adapter (the
# production chain path — devnet-only product decision); anything else uses
# the in-memory stub. HILO_PROGRAM_ID is the world_cup_hilo Anchor program
# deployed to devnet: 9u7uuj7S8kMon564b4TA8Gc7RaYXSC5QgjDz8fFgmGCU
# SOLANA_PRIVATE_KEY is the question authority + fee payer (a funded devnet
# wallet), as a JSON byte array or base58-encoded 64-byte secret key. It is
# also the gate for `pnpm test:integration`'s devnet suite, which auto-skips
# when HILO_PROGRAM_ID or SOLANA_PRIVATE_KEY is unset.
CHAIN_MODE=stub
SOLANA_RPC_URL=https://api.devnet.solana.com
HILO_PROGRAM_ID=9u7uuj7S8kMon564b4TA8Gc7RaYXSC5QgjDz8fFgmGCU
SOLANA_PRIVATE_KEY=
